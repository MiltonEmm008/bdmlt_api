# Copia este archivo como .env y ajusta los valores

# ─── Configuración básica de la API ─────────────────────────────────────────
SECRET_KEY=cambia_esta_clave_secreta_en_produccion_123456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite:///./banco.db

# Parámetros de memoria del chat de soporte
SOPORTE_MAX_MENSAJES_POR_CHAT=20
SOPORTE_MAX_CHATS_EN_RAM=200
SOPORTE_CHAT_TTL_SEGUNDOS=1800

EMAIL_USER=correo@gmail.com
EMAIL_PASSWORD="contra se nia adka"
EMAIL_OWNER=correodeduenio@gmail.com

# ─── Supabase (PostgreSQL + Storage para fotos de perfil) ───────────────────
# Para usar Supabase: comenta DATABASE_URL de SQLite y usa la siguiente.
# DATABASE_URL=postgresql+psycopg2://postgres:TU_PASSWORD@db.PROYECTO.supabase.co:5432/postgres
# SUPABASE_URL=https://PROYECTO.supabase.co
# SUPABASE_KEY=tu_anon_key_del_dashboard
# Bucket de Storage para fotos (debe existir y ser público para ver las fotos)
# SUPABASE_BUCKET_FOTOS=...